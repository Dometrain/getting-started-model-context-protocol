{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/McpClientLocalhost/bin/Debug/net10.0/McpClientLocalhost.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/McpClientLocalhost",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000",
        "Mcp__BaseUrl": "http://localhost:8080/mcp",
        "Mcp__TimeoutSeconds": "120",
        "OpenAI__ApiKey": "<OPENAI_API_KEY>"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach"
    }
  ]
}

